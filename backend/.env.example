# Copy this file to "backend/.env" and fill in real values.
# This file is used when running the backend on YOUR HOST with `npm run dev`.

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=road_quality

DETECT_CONF_THRESHOLD=0.85
# DETECT_IOU_THRESHOLD=0.45    # NMS overlap; rarely needs changing
