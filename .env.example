# Template for the root .env file used by Docker Compose.
# Copy this file to ".env" (in the same folder) and fill in real values.
#   cp .env.example .env       (Linux/Mac/Git Bash)
#   Copy-Item .env.example .env   (PowerShell)
#
# Docker Compose reads ./.env automatically when you run `docker compose ...`
# from this folder, and substitutes ${VAR} references in docker-compose.yml.
# These values then become environment variables INSIDE the containers via
# compose's `environment:` block.
#
# NOTE: backend/.env.example is a DIFFERENT file, used only when running the
# backend on your host with `npm run dev` (not in Docker).

# MySQL root password — used by:
#   - the mysql container's MYSQL_ROOT_PASSWORD
#   - the backend container's DB_PASS
DB_ROOT_PASSWORD=change-me-to-a-strong-password

# JWT signing secret — used by the backend container's JWT_SECRET.
# Generate a long random string. Example (PowerShell):
#   [System.Web.Security.Membership]::GeneratePassword(64, 0)
JWT_SECRET=change-me-to-a-long-random-string
